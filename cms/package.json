{
  "name": "tallasseetv-cms",
  "version": "1.0.0",
  "description": "Payload CMS for TallasseeTV Blog",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3000",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/storage-s3": "^3.81.0",
    "@payloadcms/translations": "^3.0.0",
    "@smithy/types": "^4.13.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.0.0",
    "next": "15.2.9",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.9.0"
  }
