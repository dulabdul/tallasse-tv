---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ArticleCard from '@/components/article/ArticleCard.astro';
import { getArticles, getSiteSettings } from '@/lib/payload';

const [articlesData, settings] = await Promise.all([
  getArticles({ limit: 7, sort: '-publishedAt' }),
  getSiteSettings().catch(() => null),
]);

const [featured, ...latestArticles] = articlesData.docs;

const pageTitle = settings?.siteName || 'TallasseeTV';
const pageDesc =
  settings?.seo?.defaultDescription ||
  'TallasseeTV — Menyajikan berita dan informasi terkini yang akurat dan terpercaya.';
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  gtmId={settings?.seo?.gtmId}
>
  <!-- ── HERO ────────────────────────────────────────────────── -->
  <section class='hero'>
    <div class='container--custom'>
      <span class='hero-label'>Blog</span>
      <h1 class='hero-title'>
        TallasseeTV Article <br />
      </h1>
      <p class='hero-subtitle'>
        Inspirasi, wawasan, dan cerita mendalam langsung dari redaksi kami.
      </p>
    </div>
  </section>

  <!-- ── FEATURED POST ────────────────────────────────────────── -->
  {
    featured && (
      <section class='featured'>
        <div class='container--custom'>
          <ArticleCard
            article={featured}
            featured={true}
          />
        </div>
      </section>
    )
  }

  <!-- ── LATEST POSTS GRID ───────────────────────────────────── -->
  <section class='latest-posts'>
    <div class='container--custom'>
      <h2 class='section-heading'>Featured blog posts</h2>
      <div class='posts-grid'>
        {latestArticles.map((article) => <ArticleCard article={article} />)}
      </div>

      <div class='view-all-container'>
        <a
          href='/artikel'
          class='btn-view-all'>
          View all posts
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .container--custom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .hero {
    padding: 6rem 0 4rem;
  }

  .hero-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    max-width: 900px;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 600px;
  }

  /* Featured */
  .featured {
    padding-bottom: 6rem;
  }

  /* Grid Section */
  .latest-posts {
    padding-bottom: 8rem;
  }

  .section-heading {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 3rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 3.5rem 2rem;
  }

  @media (min-width: 768px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .view-all-container {
    margin-top: 5rem;
    text-align: center;
  }

  .btn-view-all {
    display: inline-block;
    padding: 0.75rem 2rem;
    border: 1px solid var(--color-text-primary);
    color: var(--color-text-primary);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.875rem;
    transition:
      background var(--timing),
      color var(--timing);
  }

  .btn-view-all:hover {
    background: var(--color-text-primary);
    color: white;
  }
</style>
