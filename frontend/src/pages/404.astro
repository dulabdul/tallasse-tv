---
// Custom 404 page
import BaseLayout from '@/components/layout/BaseLayout.astro';
---

<BaseLayout
  title="404 — Halaman Tidak Ditemukan"
  description="Halaman yang Anda cari tidak dapat ditemukan. Kembali ke beranda TallasseeTV."
  noIndex={true}
>
  <div class="container not-found-wrapper">
    <div class="not-found-content animate-fade-in-up">
      <div class="error-code" aria-hidden="true">404</div>
      <h1 class="error-title">Halaman Tidak Ditemukan</h1>
      <p class="error-desc">
        Maaf, halaman yang Anda cari tidak dapat ditemukan. Mungkin halaman telah dipindahkan,
        dihapus, atau URL yang Anda masukkan salah.
      </p>

      <div class="error-actions">
        <a href="/" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Kembali ke Beranda
        </a>
        <a href="/artikel" class="btn btn-outline">Baca Artikel</a>
      </div>

      <div class="error-suggestion">
        <p>Atau coba tautan berikut:</p>
        <ul class="quick-links" role="list">
          <li><a href="/artikel">📰 Semua Artikel</a></li>
          <li><a href="/tentang-kami">📖 Tentang Kami</a></li>
          <li><a href="/kontak">📬 Kontak</a></li>
          <li><a href="/kebijakan-privasi">🔒 Kebijakan Privasi</a></li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found-wrapper {
    min-height: calc(100vh - var(--nav-height) - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1rem;
  }

  .not-found-content {
    text-align: center;
    max-width: 520px;
  }

  .error-code {
    font-size: clamp(6rem, 20vw, 10rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
    user-select: none;
  }

  .error-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .error-desc {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .error-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .error-suggestion p {
    font-size: 0.9375rem;
    color: var(--color-text-tertiary);
    margin-bottom: 0.875rem;
  }

  .quick-links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .quick-links a {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--timing);
  }

  .quick-links a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-bg);
  }
</style>
