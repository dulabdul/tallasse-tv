---
import BaseLayout from '@/components/layout/BaseLayout.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://www.tallasseetv.com';

const breadcrumbs = [
  { name: 'Beranda', url: siteUrl },
  { name: 'Tentang Kami', url: `${siteUrl}/tentang-kami` },
];

const philosophies = [
  {
    title: 'Akurasi Tanpa Kompromi',
    content: 'Informasi adalah pondasi kepercayaan. Setiap kata yang kami terbitkan melewati proses verifikasi ketat untuk memastikan kebenaran di atas segalanya.'
  },
  {
    title: 'Independensi Redaksi',
    content: 'Suara TallasseeTV murni milik publik. Kami menjaga jarak yang aman dari kepentingan politik maupun komersial demi menjaga integritas jurnalisme.'
  },
  {
    title: 'Literasi Digital',
    content: 'Kami tidak hanya menyajikan berita, tapi juga membantu masyarakat memilah arus informasi di era digital yang semakin kompleks.'
  }
];
---

<BaseLayout
  title="Tentang TallasseeTV"
  description="Membangun ekosistem informasi yang cerdas, berimbang, dan berintegritas. Kenali filosofi editorial dan misi kami untuk masyarakat."
  type="website"
  jsonLd={{ type: 'breadcrumb', data: {}, breadcrumbs }}
>
  <div class="about-container">
    <!-- Editorial Header Explorer -->
    <header class="header-minimal animate-fade-in">
      <nav class="breadcrumb-minimal" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Beranda</a></li>
          <li class="sep">/</li>
          <li class="active">Tentang Kami</li>
        </ol>
      </nav>
      <h1 class="editorial-title">Kepercayaan adalah <br/><span class="text-accent">Pondasi Jurnalistik.</span></h1>
    </header>

    <!-- Main Narrative Section -->
    <section class="section-narrative animate-fade-in-up animation-delay-100">
      <div class="narrative-grid">
        <aside class="narrative-aside">
          <p class="aside-eyebrow">TallasseeTV Story</p>
          <h2 class="aside-title">Membangun Narasi yang Berintegritas.</h2>
        </aside>
        <div class="narrative-main prose-minimal">
          <p>
            <strong>TallasseeTV</strong> hadir sebagai respon atas kebutuhan masyarakat akan informasi yang tidak hanya cepat, tapi juga memiliki kedalaman dan akurasi. Di era di mana disinformasi menjadi tantangan nyata, kami berkomitmen menjadi oase yang menjernihkan setiap isu.
          </p>
          <p>
            Kami percaya bahwa jurnalisme berkualitas adalah pilar demokrasi. Oleh karena itu, setiap konten yang kami susun—mulai dari analisis mendalam hingga berita terkini—dirancang untuk memberdayakan pembaca, bukan sekadar mengejar klik.
          </p>
          <p>
            Dengan semangat independensi, tim kami bergerak untuk menjangkau suara-suara yang sering terlewatkan, menyajikan ragam sudut pandang secara adil, dan membangun komunitas pembaca yang kritis serta cerdas.
          </p>
        </div>
      </div>
    </section>

    <!-- Philosophy Section (Minimalist List) -->
    <section class="section-philosophy animate-fade-in-up animation-delay-200">
      <div class="philosophy-header">
        <h2 class="section-label">Our Philosophy</h2>
      </div>
      <div class="philosophy-list">
        {philosophies.map((item) => (
          <div class="philosophy-item">
            <h3 class="philosophy-title">{item.title}</h3>
            <p class="philosophy-text">{item.content}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Simplified Team Impact -->
    <section class="section-impact animate-fade-in-up animation-delay-300">
      <div class="impact-content">
        <p class="impact-quote">
          "Media bukan sekadar penyampai pesan, melainkan cermin dari keberanian kita mencari kebenaran."
        </p>
        <div class="impact-meta">
          <span class="impact-author">TallasseeTV Editorial Team</span>
          <span class="impact-line"></span>
        </div>
      </div>
    </section>

    <!-- Clean Footer CTA -->
    <section class="about-footer-cta animate-fade-in-up animation-delay-300">
      <div class="cta-inner">
        <h2 class="cta-heading">Mari Membangun Komunitas yang Cerdas.</h2>
        <div class="cta-actions">
          <a href="/artikel" class="link-editorial">Baca Berita Terbaru —</a>
          <a href="/kontak" class="link-editorial">Hubungi Redaksi —</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  :root {
    --about-spacing-lg: 8rem;
    --about-spacing-md: 5rem;
    --about-spacing-sm: 2.5rem;
  }

  .about-container {
    padding-bottom: var(--about-spacing-lg);
    background: var(--color-bg);
  }

  /* Header Minimal */
  .header-minimal {
    padding-top: var(--about-spacing-md);
    padding-bottom: var(--about-spacing-sm);
    border-bottom: 1px solid var(--color-border-light);
    margin-bottom: var(--about-spacing-md);
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .breadcrumb-minimal ol {
    display: flex;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  .breadcrumb-minimal a { color: var(--color-text-tertiary); text-decoration: none; transition: color 0.3s; }
  .breadcrumb-minimal a:hover { color: var(--color-text-primary); }
  .breadcrumb-minimal .active { color: var(--color-accent); }
  .breadcrumb-minimal .sep { color: var(--color-border); }

  .editorial-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin: 0;
  }

  .text-accent {
    color: var(--color-accent);
  }

  /* Narrative Section */
  .section-narrative {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    margin-bottom: var(--about-spacing-lg);
  }

  .narrative-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .narrative-grid {
      grid-template-columns: 350px 1fr;
      gap: 6rem;
    }
  }

  .aside-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-tertiary);
    margin-bottom: 1rem;
    display: block;
  }

  .aside-title {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-text-primary);
  }

  .prose-minimal p {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .prose-minimal strong {
    color: var(--color-text-primary);
    font-weight: 700;
  }

  /* Philosophy Section */
  .section-philosophy {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--about-spacing-md) 1.5rem;
    background: var(--color-bg-secondary);
    border-radius: 2rem;
    margin-bottom: var(--about-spacing-lg);
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-text-tertiary);
    margin-bottom: 3rem;
    text-align: center;
  }

  .philosophy-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .philosophy-list {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }

  .philosophy-item {
    position: relative;
  }

  .philosophy-title {
    font-size: 1.25rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .philosophy-title::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    display: block;
  }

  .philosophy-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Impact Quote */
  .section-impact {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    margin-bottom: var(--about-spacing-lg);
    text-align: center;
  }

  .impact-quote {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-primary);
    font-style: italic;
    margin-bottom: 2rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .impact-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .impact-author {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .impact-line {
    width: 60px;
    height: 1px;
    background: var(--color-border);
  }

  /* Footer CTA */
  .about-footer-cta {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .cta-inner {
    padding: 4rem 3rem;
    background: var(--color-text-primary);
    color: var(--color-bg);
    border-radius: 2rem;
    text-align: center;
  }

  .cta-heading {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 2.5rem;
    letter-spacing: -0.03em;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .link-editorial {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-bg);
    text-decoration: none;
    transition: transform 0.3s;
    display: block;
  }

  .link-editorial:hover {
    transform: translateX(10px);
    color: var(--color-accent-light);
  }

  @media (max-width: 640px) {
    .cta-inner {
      padding: 3rem 1.5rem;
    }
  }
</style>
