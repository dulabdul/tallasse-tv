---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import SocialShare from '@/components/ui/SocialShare.astro';
import {
  getArticleBySlug,
  getAllArticleSlugs,
  getMediaUrl,
  getSiteSettings,
} from '@/lib/payload';
import { blocksToHtml, formatDate, truncate } from '@/lib/utils';

// ── Static Path Generation ─────────────────────────────────────────────────────
export async function getStaticPaths() {
  const slugs = await getAllArticleSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

// ── Data Fetching ──────────────────────────────────────────────────────────────
const { slug } = Astro.params;
const [article, settings] = await Promise.all([
  getArticleBySlug(slug as string),
  getSiteSettings(),
]);

if (!article) {
  return Astro.redirect('/404');
}

// Derived data
const siteUrl =
  import.meta.env.PUBLIC_SITE_URL || 'https://www.tallasseetv.com';
const articleUrl = `${siteUrl}/artikel/${article.slug}`;
const featuredImageUrl = getMediaUrl(article.featuredImage, 'hero');
const ogImageUrl = getMediaUrl(
  article.seo?.ogImage || article.featuredImage,
  'hero',
);

const seoTitle = article.seo?.title || article.title;
const seoDesc =
  article.seo?.description || article.excerpt || truncate(article.title, 160);
const publishDate = article.publishedAt || article.createdAt;

// Rich text → HTML
const contentHtml = blocksToHtml(article.content);
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  image={ogImageUrl}
  imageAlt={article.title}
  type='article'
  publishedAt={new Date(publishDate).toISOString()}
  updatedAt={new Date(article.updatedAt).toISOString()}
  author={article.author?.name}
  jsonLdRaw={article.jsonLd}
  gtmId={settings?.seo?.gtmId}>
  <article class='article-detail'>
    <!-- Header: Title & Categories -->
    <header class='article-header'>
      <div class='container--narrow'>
        <div class='article-category'>
          {article.categories?.[0]?.name || 'Blog'}
        </div>
        <h1 class='article-title'>{article.title}</h1>
        {article.excerpt && <p class='article-subtitle'>{article.excerpt}</p>}
      </div>
    </header>

    <!-- Hero Image -->
    <div class='article-hero'>
      <div class='container--wide'>
        <img
          src={featuredImageUrl}
          alt={article.title}
          class='hero-image'
          loading='eager'
        />
      </div>
    </div>

    <!-- Meta Bar & Share -->
    <div class='article-meta-section'>
      <div class='container--narrow'>
        <div class='meta-bar'>
          <div class='meta-left'>
            <span class='meta-label'>Written by</span>
            <span class='meta-value'>{article.author?.name || 'Redaksi'}</span>
            <span class='meta-divider'>|</span>
            <span class='meta-label'>Published on</span>
            <span class='meta-value'>{formatDate(publishDate)}</span>
          </div>
          <div class='meta-right'>
            <SocialShare
              url={articleUrl}
              title={article.title}
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class='article-content-section'>
      <div class='container--narrow'>
        <div class='prose'>
          <Fragment set:html={contentHtml} />
        </div>
      </div>
    </div>

    <!-- Footer of article (Author bio if needed, or simple Divider) -->
    <footer class='article-footer'>
      <div class='container--narrow'>
        <div class='footer-divider'></div>
        <a
          href='/artikel'
          class='back-to-blog'
          >← Back to blog</a
        >
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .article-detail {
    padding: 6rem 0 8rem;
  }

  .container--narrow {
    max-width: 850px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .container--wide {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .article-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .article-category {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    color: var(--color-text-secondary);
  }

  .article-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .article-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* Hero */
  .article-hero {
    margin-bottom: 3rem;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--color-bg-tertiary);
  }

  /* Meta Section */
  .article-meta-section {
    margin-bottom: 4rem;
  }

  .meta-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    gap: 1.5rem;
  }

  .meta-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .meta-label {
    color: var(--color-text-tertiary);
  }

  .meta-value {
    color: var(--color-text-primary);
  }

  .meta-divider {
    color: var(--color-border);
    margin: 0 0.5rem;
  }

  /* Content */
  .article-content-section {
    margin-bottom: 6rem;
  }

  /* Footer */
  .footer-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 3rem;
  }

  .back-to-blog {
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: opacity var(--timing);
  }

  .back-to-blog:hover {
    opacity: 0.7;
  }

  /* Prose refinements */
  .prose {
    font-size: 1.125rem;
    line-height: 1.8;
    color: #333;
  }

  /* Fix for images inside article content if they exist */
  .prose :global(img) {
    max-width: 100%;
    height: auto;
    margin: 2.5rem 0;
  }
</style>
