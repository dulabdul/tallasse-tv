---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ArticleCard from '@/components/article/ArticleCard.astro';
import Pagination from '@/components/ui/Pagination.astro';
import { getArticles, getCategoryBySlug, getAllCategorySlugs } from '@/lib/payload';

export async function getStaticPaths() {
  const slugs = await getAllCategorySlugs();
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const page = Number(Astro.url.searchParams.get('halaman') || '1');

const [category, articlesData] = await Promise.all([
  getCategoryBySlug(slug as string),
  getArticles({ page, limit: 9, categorySlug: slug }),
]);

if (!category) {
  return Astro.redirect('/artikel');
}

const { docs: articles, totalPages, totalDocs } = articlesData;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://tallasseetv.com';

const breadcrumbs = [
  { name: 'Beranda', url: siteUrl },
  { name: 'Artikel', url: `${siteUrl}/artikel` },
  { name: category.name, url: `${siteUrl}/kategori/${category.slug}` },
];
---

<BaseLayout
  title={`Kategori: ${category.name}${page > 1 ? ` — Halaman ${page}` : ''}`}
  description={category.description || `Artikel kategori ${category.name} di TallasseeTV. Total ${totalDocs} artikel tersedia.`}
  type="website"
  jsonLd={{ type: 'breadcrumb', data: {}, breadcrumbs }}
>
  <div class="container page-wrapper">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol role="list">
        <li><a href="/">Beranda</a></li>
        <li aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></li>
        <li><a href="/artikel">Artikel</a></li>
        <li aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></li>
        <li><span aria-current="page">{category.name}</span></li>
      </ol>
    </nav>

    <!-- Header -->
    <header class="page-header animate-fade-in-up">
      <div class="cat-header-inner">
        {category.color && (
          <div class="cat-color-dot" style={`background: ${category.color}`} aria-hidden="true"></div>
        )}
        <div>
          <span class="cat-label">Kategori</span>
          <h1 class="page-title">{category.name}</h1>
          {category.description && <p class="page-desc">{category.description}</p>}
          <p class="article-count-text">
            Menampilkan <strong>{totalDocs}</strong> artikel dalam kategori ini
            {page > 1 && <> — Halaman {page}</>}
          </p>
        </div>
      </div>
    </header>

    <!-- Grid -->
    {articles.length > 0 ? (
      <div class="articles-grid">
        {articles.map((article, i) => (
          <div class={`animate-fade-in-up animation-delay-${Math.min((i % 3 + 1) * 100, 300)}`}>
            <ArticleCard article={article} />
          </div>
        ))}
      </div>

      <Pagination
        currentPage={page}
        totalPages={totalPages}
        baseUrl={`/kategori/${category.slug}`}
      />
    ) : (
      <div class="empty-state animate-fade-in">
        <div class="empty-icon" aria-hidden="true">📭</div>
        <h2 class="empty-title">Belum Ada Artikel</h2>
        <p class="empty-desc">Belum ada artikel di kategori ini. Silakan cek kembali nanti.</p>
        <a href="/artikel" class="btn btn-primary">Lihat Semua Artikel</a>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-wrapper { padding: 2.5rem 0 4rem; }

  .breadcrumb ol {
    display: flex; align-items: center; gap: 0.3rem;
    list-style: none; padding: 0; margin: 0 0 1.5rem;
    font-size: 0.8125rem; flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--color-text-tertiary); text-decoration: none; transition: color var(--timing); }
  .breadcrumb a:hover { color: var(--color-accent); }
  .breadcrumb span { color: var(--color-text-secondary); font-weight: 500; }

  .page-header { margin-bottom: 2rem; }

  .cat-header-inner {
    display: flex; align-items: flex-start; gap: 1.25rem;
  }

  .cat-color-dot {
    width: 6px; min-height: 80px; border-radius: 4px;
    flex-shrink: 0; margin-top: 0.375rem;
  }

  .cat-label {
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--color-accent);
    display: block; margin-bottom: 0.25rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800;
    letter-spacing: -0.03em; color: var(--color-text-primary); margin-bottom: 0.5rem;
  }

  .page-desc { color: var(--color-text-secondary); font-size: 1.0625rem; margin-bottom: 0.5rem; }

  .article-count-text { font-size: 0.9375rem; color: var(--color-text-tertiary); }
  .article-count-text strong { color: var(--color-text-secondary); }

  .articles-grid {
    display: grid; grid-template-columns: 1fr; gap: 1.5rem;
  }
  @media (min-width: 640px) { .articles-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .articles-grid { grid-template-columns: repeat(3, 1fr); } }

  .empty-state {
    text-align: center; padding: 5rem 1rem;
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
  }
  .empty-icon { font-size: 3.5rem; }
  .empty-title { font-size: 1.5rem; font-weight: 700; color: var(--color-text-primary); }
  .empty-desc { color: var(--color-text-secondary); }
</style>
