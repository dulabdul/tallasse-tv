---
import type { Article } from '@/lib/payload';
import { getRelatedArticles, getMediaUrl } from '@/lib/payload';
import { formatDateShort, formatReadingTime } from '@/lib/utils';
import ModernImage from '@/components/ui/ModernImage.astro';

interface Props {
  articleId: string;
  categoryIds: string[];
  limit?: number;
}

const { articleId, categoryIds, limit = 3 } = Astro.props;
const related = await getRelatedArticles(articleId, categoryIds, limit);
---

{related.length > 0 && (
  <aside class="related-articles" aria-label="Artikel Terkait">
    <h2 class="section-title">Artikel Terkait</h2>

    <div class="related-grid">
      {related.map((article: Article, i: number) => (
        <article
          class="related-card animate-fade-in-up"
          style={`animation-delay: ${i * 80}ms`}
          aria-label={`Artikel terkait: ${article.title}`}
        >
          <a href={`/artikel/${article.slug}`} class="related-img-link" tabindex="-1" aria-hidden="true">
            <div class="related-img-wrap">
              <ModernImage
                media={article.featuredImage}
                size="thumbnail"
                alt={article.featuredImage?.alt || article.title}
                class="related-img"
                loading="lazy"
                decoding="async"
                width={400}
                height={300}
              />
            </div>
          </a>
          <div class="related-body">
            {article.categories?.[0] && (
              <a href={`/kategori/${article.categories[0].slug}`} class="badge badge-accent related-cat">
                {article.categories[0].name}
              </a>
            )}
            <h3 class="related-title">
              <a href={`/artikel/${article.slug}`} class="related-title-link">
                {article.title}
              </a>
            </h3>
            <div class="related-meta">
              <time
                datetime={new Date(article.publishedAt || article.createdAt).toISOString()}
                class="related-date"
              >
                {formatDateShort(article.publishedAt || article.createdAt)}
              </time>
              {article.readingTime && (
                <span class="related-time">· {formatReadingTime(article.readingTime)}</span>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </aside>
)}

<style>
  .related-articles {
    margin: 6rem 0;
    padding-top: 4rem;
    border-top: 1px solid var(--color-border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    group: hover;
  }

  .related-img-wrap {
    aspect-ratio: 16/10;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-bg-secondary);
  }

  .related-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--timing);
  }

  .related-card:hover .related-img {
    transform: scale(1.08);
  }

  .related-cat {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent-blue);
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .related-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    color: var(--color-text-primary);
    transition: color var(--timing);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-card:hover .related-title {
    color: var(--color-accent-blue);
  }

  .related-meta {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
  }
</style>
