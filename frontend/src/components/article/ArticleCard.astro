---
import type { Article } from '@/lib/payload';
import { getMediaUrl } from '@/lib/payload';
import { formatDateShort, formatReadingTime } from '@/lib/utils';
import ModernImage from '@/components/ui/ModernImage.astro'; // Added imported wrapper Component

interface Props {
  article: Article;
  featured?: boolean;
  class?: string;
}

const { article, featured = false, class: className } = Astro.props;

// imageUrl remains here for fallback/logic mapping if needed by the caller, though ModernImage handles extraction
const imageUrl = getMediaUrl(article.featuredImage, featured ? 'hero' : 'card');
const date = article.publishedAt || article.createdAt;
const category = article.categories?.[0]?.name || 'Uncategorized';
---

<article class={`article-card ${featured ? 'article-card--featured' : ''} ${className || ''}`}>
  <a href={`/artikel/${article.slug}`} class="card-link">
    <div class="card-image-wrapper">
      <ModernImage
        media={article.featuredImage}
        size={featured ? 'hero' : 'card'}
        alt={article.title}
        class="card-image"
        loading="lazy"
        decoding="async"
      />
      <div class="card-category-badge">{category}</div>
    </div>

    <div class="card-body">
      <div class="card-header">
        <div class="card-meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          <time datetime={date}>{formatDateShort(date)}</time>
        </div>
        <span class="meta-separator">/</span>
        {article.readingTime && (
          <div class="card-meta-item">
             <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            <span>{formatReadingTime(article.readingTime)}</span>
          </div>
        )}
      </div>

      <h3 class="card-title-heading">
        {article.title}
      </h3>

      <p class="card-summary">
        {article.excerpt || article.title}
      </p>

      <div class="card-action">
        <span class="action-text">Pelajari Lebih Lanjut</span>
        <svg class="action-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </div>
    </div>
  </a>
</article>

<style>
  .article-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    height: 100%;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .article-card:hover {
    transform: translateY(-8px);
    border-color: var(--color-accent);
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.12);
  }

  [data-theme="dark"] .article-card:hover {
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.4);
    background: var(--color-bg-secondary);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .card-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-tertiary);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .article-card:hover .card-image {
    transform: scale(1.1);
  }

  .card-category-badge {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    background: var(--color-text-primary);
    color: var(--color-bg);
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: var(--radius-sm);
    z-index: 10;
    box-shadow: 0 8px 16px rgba(0,0,0,0.2);
    transition: all 0.3s ease;
  }

  [data-theme="dark"] .card-category-badge {
    background: var(--color-accent);
    color: #000;
  }

  .article-card:hover .card-category-badge {
    transform: translateY(-4px);
    background: var(--color-accent);
    color: #000;
  }

  .card-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 1.25rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
  }

  .card-meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .meta-separator {
    opacity: 0.3;
  }

  .card-title-heading {
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1.25;
    color: var(--color-text-primary);
    margin: 0;
    transition: color var(--timing);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    letter-spacing: -0.02em;
  }

  .article-card:hover .card-title-heading {
    color: var(--color-accent);
  }

  .card-summary {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-action {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9375rem;
    font-weight: 800;
    color: var(--color-text-primary);
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border-subtle);
    transition: all var(--timing);
  }

  .action-icon {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .article-card:hover .card-action {
    color: var(--color-accent);
  }

  .article-card:hover .action-icon {
    transform: translateX(8px);
  }

  /* Featured Variation (Hero Section style) */
  @media (min-width: 1024px) {
    .article-card--featured {
      border: none;
      background: transparent;
      padding: 0;
    }
    
    .article-card--featured:hover {
      transform: none;
      box-shadow: none;
      background: transparent;
    }

    .article-card--featured .card-link {
      flex-direction: row;
      gap: 4rem;
      align-items: center;
    }

    .article-card--featured .card-image-wrapper {
      flex: 1.4;
      aspect-ratio: 16 / 9;
      border-radius: var(--radius-3xl);
      box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.2);
    }

    .article-card--featured .card-body {
      flex: 1;
      padding: 0;
    }

    .article-card--featured .card-title-heading {
      font-size: 3.5rem;
      -webkit-line-clamp: 3;
    }

    .article-card--featured .card-summary {
      font-size: 1.25rem;
      -webkit-line-clamp: 4;
    }
    
    .article-card--featured .card-action {
      border: none;
      padding: 0;
    }
  }
</style>
