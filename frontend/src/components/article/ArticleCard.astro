---
import type { Article } from '@/lib/payload';
import { getMediaUrl } from '@/lib/payload';
import { formatDateShort, formatReadingTime, truncate } from '@/lib/utils';

interface Props {
  article: Article;
  featured?: boolean;
  class?: string;
}

const { article, featured = false, class: className } = Astro.props;

const imageUrl = getMediaUrl(article.featuredImage, featured ? 'hero' : 'card');
const excerpt = article.excerpt || truncate(article.title, 120);
const date = article.publishedAt || article.createdAt;
---

<article
  class={`article-card ${featured ? 'article-card--featured' : 'hover-lift'} ${className || ''}`}
>
  <a href={`/artikel/${article.slug}`} class="card-link" aria-label={article.title}>
    <div class="card-image-container">
      <img
        src={imageUrl}
        alt={article.featuredImage?.alt || article.title}
        class="card-image"
        loading="lazy"
        decoding="async"
      />
      
      <div class="card-badges">
        {article.categories?.slice(0, 1).map(cat => (
          <span class="badge badge-glass">{cat.name}</span>
        ))}
      </div>
    </div>

    <div class="card-content">
      <div class="card-header">
        <time datetime={new Date(date).toISOString()} class="card-date">
          {formatDateShort(date)}
        </time>
        {article.readingTime && (
          <span class="card-read-time">
            • {formatReadingTime(article.readingTime)}
          </span>
        )}
      </div>

      <h3 class={`card-title ${featured ? 'text-2xl md:text-3xl' : 'text-lg'}`}>
        {article.title}
      </h3>

      {featured && <p class="card-excerpt">{excerpt}</p>}

      <div class="card-footer">
        <div class="author-info">
          {article.author?.profilePicture ? (
            <img
              src={getMediaUrl(article.author.profilePicture, 'thumbnail')}
              alt={article.author.name}
              class="author-avatar"
            />
          ) : (
            <div class="author-avatar-placeholder">{article.author?.name?.charAt(0)}</div>
          )}
          <span class="author-name">{article.author?.name || 'Redaksi'}</span>
        </div>
        
        <span class="read-more">
          Baca Selengkapnya
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </span>
      </div>
    </div>
  </a>
</article>

<style>
  .article-card {
    position: relative;
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    height: 100%;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .card-image-container {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-tertiary);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .article-card:hover .card-image {
    transform: scale(1.08);
  }

  .card-badges {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: flex;
    gap: 0.5rem;
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 0.75rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-title {
    margin: 0;
    color: var(--color-text-primary);
    transition: color var(--timing);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card:hover .card-title {
    color: var(--color-accent-blue);
  }

  .card-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0.25rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--color-border-subtle);
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .author-avatar, .author-avatar-placeholder {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-avatar-placeholder {
    background: var(--color-bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-tertiary);
  }

  .author-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-accent-blue);
    opacity: 0;
    transform: translateX(-10px);
    transition: all var(--timing);
  }

  .article-card:hover .read-more {
    opacity: 1;
    transform: translateX(0);
  }

  /* Featured Variation */
  .article-card--featured {
    display: grid;
    grid-template-columns: 1fr;
    border: none;
    background: transparent;
  }

  @media (min-width: 1024px) {
    .article-card--featured {
      grid-template-columns: 1.2fr 1fr;
      gap: 2rem;
      align-items: center;
    }
    .article-card--featured .card-image-container {
      aspect-ratio: 16 / 9;
      border-radius: var(--radius-2xl);
      box-shadow: var(--shadow-premium);
    }
    .article-card--featured .card-content {
      padding: 0;
    }
    .article-card--featured .card-title {
      font-size: 2.5rem;
      line-height: 1.1;
    }
  }
</style>
