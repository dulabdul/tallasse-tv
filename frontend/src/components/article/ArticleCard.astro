---
import type { Article } from '@/lib/payload';
import { getMediaUrl } from '@/lib/payload';
import { formatDateShort, formatReadingTime } from '@/lib/utils';

interface Props {
  article: Article;
  featured?: boolean;
  class?: string;
}

const { article, featured = false, class: className } = Astro.props;

const imageUrl = getMediaUrl(article.featuredImage, featured ? 'hero' : 'card');
const date = article.publishedAt || article.createdAt;
const category = article.categories?.[0]?.name || 'Uncategorized';
---

<article class={`article-card ${featured ? 'article-card--featured' : ''} ${className || ''}`}>
  <a href={`/artikel/${article.slug}`} class="card-link">
    <div class="card-image-container">
      <img
        src={imageUrl}
        alt={article.title}
        class="card-image"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="card-content">
      <div class="card-meta">
        <span class="card-category">{category}</span>
        {article.readingTime && (
          <span class="card-read-time">{formatReadingTime(article.readingTime)}</span>
        )}
      </div>

      <h3 class="card-title">
        {article.title}
      </h3>

      <p class="card-excerpt">
        {article.excerpt || article.title}
      </p>

      <div class="card-footer">
        <span class="read-more">
          Read more
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </span>
      </div>
    </div>
  </a>
</article>

<style>
  .article-card {
    background: var(--color-bg);
    transition: opacity var(--timing);
  }

  .article-card:hover {
    opacity: 0.9;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .card-image-container {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    margin-bottom: 1.25rem;
    background: var(--color-bg-tertiary);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .card-category {
    color: var(--color-text-primary);
  }

  .card-read-time {
    color: var(--color-text-secondary);
  }

  .card-title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 0.75rem;
    color: var(--color-text-primary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0 0 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  /* Featured Variation (Hero Section style) */
  @media (min-width: 1024px) {
    .article-card--featured .card-link {
      flex-direction: row;
      gap: 3rem;
      align-items: center;
    }
    .article-card--featured .card-image-container {
      flex: 1.2;
      margin-bottom: 0;
      aspect-ratio: 16 / 10;
    }
    .article-card--featured .card-content {
      flex: 1;
    }
    .article-card--featured .card-title {
      font-size: 2.25rem;
    }
  }
</style>
