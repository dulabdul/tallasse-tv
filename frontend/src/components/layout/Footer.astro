---
import { getSiteSettings } from '@/lib/payload';

const settings = await getSiteSettings().catch(() => ({
  siteName: 'TallasseeTV',
  footerText: '© 2025 TallasseeTV. Semua hak dilindungi.',
  footerDescription: 'Menyajikan berita dan informasi terkini yang akurat dan terpercaya.',
  socialLinks: [],
  contact: { email: 'redaksi@tallasseetv.com' },
}));

const year = new Date().getFullYear();

const footerLinks = [
  {
    heading: 'Navigasi',
    links: [
      { label: 'Beranda', href: '/' },
      { label: 'Semua Artikel', href: '/artikel' },
      { label: 'Tentang Kami', href: '/tentang-kami' },
      { label: 'Kontak', href: '/kontak' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Kebijakan Privasi', href: '/kebijakan-privasi' },
      { label: 'Tentang Kami', href: '/tentang-kami' },
    ],
  },
];

const socialIconMap: Record<string, string> = {
  facebook: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  twitter: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  youtube: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/></svg>`,
  tiktok: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.27 8.27 0 0 0 4.83 1.56V6.78a4.85 4.85 0 0 1-1.06-.09z"/></svg>`,
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
  linkedin: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
};
---

<footer class="site-footer" role="contentinfo">
  <!-- Main footer content -->
  <div class="container footer-grid">
    <!-- Brand column -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label={`${settings.siteName} — Beranda`}>
        <span class="footer-logo-text">{settings.siteName}</span>
      </a>
      {settings.footerDescription && (
        <p class="footer-desc">{settings.footerDescription}</p>
      )}
      <!-- Social Links -->
      {settings.socialLinks && settings.socialLinks.length > 0 && (
        <div class="social-links" aria-label="Media Sosial">
          {settings.socialLinks.map(link => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              aria-label={link.label || link.platform}
              title={link.label || link.platform}
            >
              <Fragment set:html={socialIconMap[link.platform] || '🔗'} />
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Link columns -->
    {footerLinks.map(col => (
      <div class="footer-col">
        <h3 class="footer-col-heading">{col.heading}</h3>
        <ul role="list">
          {col.links.map(link => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <!-- Contact column -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Kontak</h3>
      <ul role="list" class="contact-list">
        {settings.contact?.email && (
          <li>
            <a href={`mailto:${settings.contact.email}`} class="footer-link contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
              {settings.contact.email}
            </a>
          </li>
        )}
        {settings.contact?.phone && (
          <li>
            <a href={`tel:${settings.contact.phone}`} class="footer-link contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.6 4.35 2 2 0 0 1 3.57 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.18 6.18l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              {settings.contact.phone}
            </a>
          </li>
        )}
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">
        {settings.footerText?.replace('2025', String(year)) || `© ${year} ${settings.siteName}. Semua hak dilindungi.`}
      </p>
      <p class="footer-built">
        Dibangun dengan
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="footer-tech-link">Astro</a>
        &amp;
        <a href="https://payloadcms.com" target="_blank" rel="noopener noreferrer" class="footer-tech-link">Payload CMS</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
    .footer-brand {
      grid-column: auto;
    }
  }

  /* Brand */
  .footer-logo {
    display: inline-block;
    margin-bottom: 0.75rem;
    text-decoration: none;
  }

  .footer-logo-text {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-desc {
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
    line-height: 1.65;
    margin-bottom: 1.25rem;
    max-width: 280px;
  }

  /* Social */
  .social-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-tertiary);
    transition: all var(--timing);
    text-decoration: none;
  }

  .social-link:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
    transform: translateY(-1px);
  }

  /* Columns */
  .footer-col-heading {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--timing);
  }

  .footer-link:hover {
    color: var(--color-accent);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .contact-list {
    gap: 0.75rem !important;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }

  .footer-bottom-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .footer-copy {
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
  }

  .footer-built {
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }

  .footer-tech-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--timing);
  }

  .footer-tech-link:hover {
    color: var(--color-accent-light);
  }
</style>
