---
/**
 * SocialShare — Share buttons: Facebook, LinkedIn, X, WhatsApp, Copy Link
 */
import { getSocialShareUrls } from '@/lib/utils';

interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const shareUrls = getSocialShareUrls(url, title);

const buttons = [
  {
    id: 'share-facebook',
    label: 'Bagikan ke Facebook',
    href: shareUrls.facebook,
    color: '#1877f2',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
    text: 'Facebook',
  },
  {
    id: 'share-twitter',
    label: 'Bagikan ke X (Twitter)',
    href: shareUrls.twitter,
    color: '#000000',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
    text: 'X (Twitter)',
  },
  {
    id: 'share-linkedin',
    label: 'Bagikan ke LinkedIn',
    href: shareUrls.linkedin,
    color: '#0a66c2',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
    text: 'LinkedIn',
  },
  {
    id: 'share-whatsapp',
    label: 'Bagikan ke WhatsApp',
    href: shareUrls.whatsapp,
    color: '#25d366',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
    text: 'WhatsApp',
  },
];
---

<div class="social-share" aria-label="Bagikan artikel ini">
  <span class="share-label">Bagikan:</span>

  <div class="share-buttons" role="list">
    {buttons.map(btn => (
      <a
        id={btn.id}
        href={btn.href}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn"
        aria-label={btn.label}
        title={btn.label}
        style={`--btn-color: ${btn.color}`}
        role="listitem"
      >
        <Fragment set:html={btn.icon} />
        <span class="share-btn-text">{btn.text}</span>
      </a>
    ))}

    <!-- Copy Link button -->
    <button
      id="copy-link-btn"
      class="share-btn share-btn--copy"
      aria-label="Salin tautan artikel"
      title="Salin tautan"
      type="button"
      data-url={url}
      role="listitem"
    >
      <svg id="copy-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
      </svg>
      <svg id="check-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      <span class="share-btn-text" id="copy-text">Salin Tautan</span>
    </button>
  </div>
</div>

<style>
  .social-share {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .share-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  .share-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    cursor: pointer;
    text-decoration: none;
    transition: all var(--timing);
    white-space: nowrap;
  }

  .share-btn:hover {
    background: var(--btn-color, var(--color-accent));
    border-color: var(--btn-color, var(--color-accent));
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--btn-color, var(--color-accent)) 40%, transparent);
  }

  .share-btn--copy {
    --btn-color: #6366f1;
  }

  .share-btn--copy.copied {
    background: var(--color-success);
    border-color: var(--color-success);
    color: white;
  }

  .share-btn-text {
    display: none;
  }

  @media (min-width: 480px) {
    .share-btn-text {
      display: inline;
    }
  }

  .hidden {
    display: none;
  }
</style>

<script>
  const copyBtn = document.getElementById('copy-link-btn');
  const copyText = document.getElementById('copy-text');
  const copyIcon = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');

  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.dataset.url || window.location.href;
    try {
      await navigator.clipboard.writeText(url);
      // Success state
      copyBtn.classList.add('copied');
      if (copyText) copyText.textContent = 'Tersalin!';
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');

      setTimeout(() => {
        copyBtn.classList.remove('copied');
        if (copyText) copyText.textContent = 'Salin Tautan';
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
      }, 2000);
    } catch {
      // Fallback
      const input = document.createElement('input');
      input.value = url;
      document.body.appendChild(input);
      input.select();
      document.execCommand('copy');
      document.body.removeChild(input);
    }
  });
</script>
