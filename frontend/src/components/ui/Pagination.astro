---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string; // e.g. "/artikel" or "/kategori/berita"
}

const { currentPage, totalPages, baseUrl } = Astro.props;

if (totalPages <= 1) {
  // No pagination needed
}

function getPageUrl(page: number) {
  if (page === 1) return baseUrl;
  return `${baseUrl}?halaman=${page}`;
}

// Generate page numbers array with ellipsis (…)
function getPageNumbers(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);

  const pages: (number | '...')[] = [1];

  if (current > 3) pages.push('...');

  const start = Math.max(2, current - 1);
  const end = Math.min(total - 1, current + 1);

  for (let i = start; i <= end; i++) pages.push(i);

  if (current < total - 2) pages.push('...');

  pages.push(total);
  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
const prevPage = currentPage > 1 ? currentPage - 1 : null;
const nextPage = currentPage < totalPages ? currentPage + 1 : null;
---

{totalPages > 1 && (
  <nav class="pagination" aria-label="Navigasi Halaman">
    <!-- Previous -->
    {prevPage ? (
      <a
        href={getPageUrl(prevPage)}
        class="page-btn page-btn--nav"
        aria-label={`Halaman sebelumnya (${prevPage})`}
        rel="prev"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        <span>Sebelumnya</span>
      </a>
    ) : (
      <span class="page-btn page-btn--nav page-btn--disabled" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        <span>Sebelumnya</span>
      </span>
    )}

    <!-- Page numbers -->
    <ol class="page-numbers" role="list" aria-label="Daftar halaman">
      {pageNumbers.map((page) => (
        <li>
          {page === '...' ? (
            <span class="page-ellipsis" aria-hidden="true">…</span>
          ) : page === currentPage ? (
            <span
              class="page-btn page-btn--current"
              aria-current="page"
              aria-label={`Halaman ${page}, halaman saat ini`}
            >
              {page}
            </span>
          ) : (
            <a
              href={getPageUrl(page as number)}
              class="page-btn"
              aria-label={`Halaman ${page}`}
            >
              {page}
            </a>
          )}
        </li>
      ))}
    </ol>

    <!-- Next -->
    {nextPage ? (
      <a
        href={getPageUrl(nextPage)}
        class="page-btn page-btn--nav"
        aria-label={`Halaman berikutnya (${nextPage})`}
        rel="next"
      >
        <span>Berikutnya</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    ) : (
      <span class="page-btn page-btn--nav page-btn--disabled" aria-hidden="true">
        <span>Berikutnya</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </span>
    )}
  </nav>
)}

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 2rem 0;
    flex-wrap: wrap;
  }

  .page-numbers {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    min-width: 2.25rem;
    height: 2.25rem;
    padding: 0 0.625rem;
    font-size: 0.9375rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--timing);
    cursor: pointer;
  }

  .page-btn:hover:not(.page-btn--current):not(.page-btn--disabled) {
    background: var(--color-accent-bg);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .page-btn--current {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
    cursor: default;
    font-weight: 600;
  }

  .page-btn--disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .page-btn--nav {
    padding: 0 0.875rem;
    font-size: 0.875rem;
  }

  .page-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    height: 2.25rem;
    color: var(--color-text-tertiary);
    font-size: 0.9375rem;
  }
</style>
