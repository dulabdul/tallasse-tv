---
/**
 * SEO Component — Dynamic meta tags + Open Graph + Twitter Card
 */
interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  url?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedAt?: string;
  updatedAt?: string;
  author?: string;
  noIndex?: boolean;
  siteName?: string;
  googleVerification?: string;
}

const {
  title,
  description = 'TallasseeTV — Menyajikan berita dan informasi terkini yang akurat dan terpercaya.',
  image = '/images/og-default.jpg',
  imageAlt = 'TallasseeTV',
  url, // Kept for backwards compatibility if passed explicitly
  canonicalUrl,
  type = 'website',
  publishedAt,
  updatedAt,
  author,
  noIndex = false,
  siteName = 'TallasseeTV',
  googleVerification,
} = Astro.props;

// Use Astro.site to enforce the production domain avoiding Vercel localhost internal proxy leaks
const baseUrl = import.meta.env.PUBLIC_SITE_URL || Astro.site?.href || 'https://www.tallasseetv.com';
// Normalize baseUrl to not have a trailing slash, and pathname to have a leading slash
const normalizedBase = baseUrl.replace(/\/$/, '');
const normalizedPath = Astro.url.pathname.startsWith('/') ? Astro.url.pathname : `/${Astro.url.pathname}`;
const safeUrl = `${normalizedBase}${normalizedPath}`;

const canonical = canonicalUrl || url || safeUrl;
const fullTitle = title.includes(siteName) ? title : `${title} — ${siteName}`;
const absoluteImage = image.startsWith('http')
  ? image
  : `${import.meta.env.PUBLIC_SITE_URL || 'https://www.tallasseetv.com'}${image}`;
---

<!-- Primary Meta -->
<title>{fullTitle}</title>
<meta
  name='description'
  content={description}
/>
{
  noIndex && (
    <meta
      name='robots'
      content='noindex, nofollow'
    />
  )
}
{
  !noIndex && (
    <meta
      name='robots'
      content='index, follow'
    />
  )
}
<link
  rel='canonical'
  href={canonical}
/>

<!-- Google Verification -->
{
  googleVerification && (
    <meta
      name='google-site-verification'
      content={googleVerification}
    />
  )
}

<!-- Open Graph -->
<meta
  property='og:site_name'
  content={siteName}
/>
<meta
  property='og:title'
  content={fullTitle}
/>
<meta
  property='og:description'
  content={description}
/>
<meta
  property='og:url'
  content={url}
/>
<meta
  property='og:type'
  content={type}
/>
<meta
  property='og:image'
  content={absoluteImage}
/>
<meta
  property='og:image:alt'
  content={imageAlt}
/>
<meta
  property='og:image:width'
  content='1200'
/>
<meta
  property='og:image:height'
  content='630'
/>
<meta
  property='og:locale'
  content='id_ID'
/>

<!-- Twitter Card -->
<meta
  name='twitter:card'
  content='summary_large_image'
/>
<meta
  name='twitter:title'
  content={fullTitle}
/>
<meta
  name='twitter:description'
  content={description}
/>
<meta
  name='twitter:image'
  content={absoluteImage}
/>
<meta
  name='twitter:image:alt'
  content={imageAlt}
/>

<!-- Article specific -->
{
  type === 'article' && publishedAt && (
    <meta
      property='article:published_time'
      content={publishedAt}
    />
  )
}
{
  type === 'article' && updatedAt && (
    <meta
      property='article:modified_time'
      content={updatedAt}
    />
  )
}
{
  type === 'article' && author && (
    <meta
      property='article:author'
      content={author}
    />
  )
}
